{
  "name": "grunt-boilerplate",
  "version": "0.1.0",
  "description": "An original, production-ready Grunt + LESS boilerplate for static sites, marketing pages, docs sites, and pattern libraries.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vranjan7077/grunt-boilerplate.git"
  },
  "homepage": "https://github.com/Vranjan7077/grunt-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/Vranjan7077/grunt-boilerplate/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "grunt dev",
    "build": "grunt build",
    "lint": "grunt lint",
    "lint:js": "grunt eslint",
    "lint:css": "grunt stylelint",
    "lint:html": "grunt htmlvalidate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "grunt test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.5.2",
